{
  "name": "ihatepdf",
  "private": false,
  "version": "0.1.0",
  "homepage": "https://hatemecha.github.io/iHatePDF/",
  "license": "MIT",
  "author": "Alex Romero (hatemecha)",
  "repository": {
    "type": "git",
    "url": "https://github.com/hatemecha/iHatePDF.git"
  },
  "keywords": [
    "pdf",
    "react",
    "vite",
    "browser-tools"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "type": "module",
  "description": "Herramientas PDF privadas que funcionan desde una web.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:pages": "tsc -b && vite build --base=/iHatePDF/ && node scripts/create-spa-fallback.mjs",
    "preview": "vite preview",
    "preview:pages": "vite preview --base=/iHatePDF/",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "generate:brand": "node scripts/generate-brand-assets.mjs"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jszip": "^3.10.1",
    "lenis": "^1.3.23",
    "lucide-react": "^1.14.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.7.284",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^22.19.17",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
